Task :  Player score counter - 

- Pick 4 random players from a list of 10
- Calculate random scores for each player - 1,10
- Bonus multiplier - Factorial of all scores (This is the final score)


Output - 
[4 players]
Scores before bonus
scores after bonus


                         
import random
import math

# List of 10 players
players = [
    "Player1", "Player2", "Player3", "Player4", "Player5",
    "Player6", "Player7", "Player8", "Player9", "Player10"
]

# Pick 4 random players
selected_players = random.sample(players, 4)

# Generate random scores between 1 and 10
scores_before_bonus = {player: random.randint(1, 10) for player in selected_players}

# Apply bonus multiplier (Factorial of the score)
scores_after_bonus = {player: math.factorial(score) 
                      for player, score in scores_before_bonus.items()}

# Output
print("Selected Players:")
for player in selected_players:
    print(player)

print("\nScores Before Bonus:")
for player, score in scores_before_bonus.items():
    print(f"{player}: {score}")

print("\nScores After Bonus (Factorial Applied):")
for player, score in scores_after_bonus.items():
    print(f"{player}: {score}")

